# Paciolus Overnight Agent System — Environment Variables
# Copy this file to .env.overnight and fill in the values.

# Anthropic (REQUIRED — Scout + Briefing Compiler use Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Reddit API (OPTIONAL — Scout uses Claude web search as primary; PRAW as fallback)
# Get credentials at https://www.reddit.com/prefs/apps (create "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=paciolus-scout/1.0 by u/YOUR_USERNAME
