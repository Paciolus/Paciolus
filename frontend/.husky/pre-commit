# Sprint 496: Secrets scanning gate + lint-staged
# Sprint 498: Frontend test gate — auto-runs Jest when frontend/src/ files are staged
# Reject commits containing high-entropy secrets or known secret patterns.

# ── Secrets pattern check (no external dependency) ──────────────
# Scans staged files for common secret patterns.
# This catches the most dangerous cases without requiring trufflehog locally.
# Note: Excludes .husky/ to avoid self-matching on the pattern definition.
SECRETS_FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '\.husky/')

if [ -n "$STAGED_FILES" ]; then
  # Build pattern from fragments to avoid self-matching in diffs
  SK="sk_live_|sk_test_|whsec_"
  AWS="AKIA[0-9A-Z]{16}"
  PEM="-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----"
  GH="ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|github_pat_[a-zA-Z0-9_]{82}"
  SLACK="xox[bpoas]-[0-9a-zA-Z-]{10,}"
  SECRET_PATTERNS="($SK|$AWS|$PEM|$GH|$SLACK)"

  # Only scan diffs of non-hook files
  if git diff --cached -U0 -- $STAGED_FILES | grep -qEi "$SECRET_PATTERNS"; then
    echo "ERROR: Potential secret detected in staged changes!"
    echo "Matches found for patterns: Stripe keys, AWS keys, private keys, GitHub tokens, Slack tokens"
    echo ""
    echo "If this is a false positive (e.g., in .env.example or documentation),"
    echo "you can bypass with: git commit --no-verify"
    echo ""
    echo "Matched lines:"
    git diff --cached -U0 -- $STAGED_FILES | grep -Eni "$SECRET_PATTERNS" | head -5
    SECRETS_FOUND=1
  fi
fi

if [ "$SECRETS_FOUND" -eq 1 ]; then
  exit 1
fi

# ── Frontend test gate (only when frontend/src/ files are staged) ─
FRONTEND_SRC_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^frontend/src/' || true)
if [ -n "$FRONTEND_SRC_CHANGED" ]; then
  echo "Frontend source files changed — running Jest test gate..."
  (cd frontend && npx jest --bail --ci --forceExit 2>&1)
  if [ $? -ne 0 ]; then
    echo ""
    echo "ERROR: Frontend tests failed. Fix failures before committing."
    exit 1
  fi
  echo "Frontend tests passed."
fi

# ── Lint-staged (existing) ───────────────────────────────────────
cd frontend && npx lint-staged
